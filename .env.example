# Copy to .env.local and point to private local datasets.
# .env.local is intentionally ignored by git.

ATS_JOB_PARQUET=/absolute/path/to/job_training_dataset_v1.parquet
# Optional. Use only a resume corpus you have permission to process.
ATS_AUTHORIZED_RESUME_ZIP=/absolute/path/to/authorized-resumes.zip
ATS_MODEL_DIR=./models
